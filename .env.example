### Application
PROJECT_NAME=olxPriceWatcher
APP_ENV=dev
APP_SECRET=change_me
APP_BASE_URL=http://localhost:8000

### PostgreSQL Configuration
POSTGRES_USER=userolxpricewatcher
POSTGRES_PASSWORD=change_me
POSTGRES_DB=dbolxpricewatcher
POSTGRES_HOST=database
# Host port exposed for local database tools. Containers always connect to PostgreSQL on database:5432.
POSTGRES_PORT=5432

### Mailer
# Local Docker setup uses Mailpit.
# Mailpit UI: http://localhost:8025
# For real SMTP, replace this DSN with provider settings.
MAILER_DSN=smtp://mailpit:1025
MAIL_FROM=no-reply@example.com

### Localization
# Supported values: ua, en
LOCALE=ua

### Email rate limiting
# Minimum number of seconds between emails sent to the same recipient.
EMAIL_RATE_LIMIT_SECONDS=60

### OLX Fetching
OLX_CHECK_INTERVAL_FROM_SECONDS=300
OLX_CHECK_INTERVAL_TO_SECONDS=600
# Number of consecutive 404/not_found checks after which active subscribers are notified that the listing is unavailable.
OLX_UNAVAILABLE_NOTIFICATION_THRESHOLD=20
OLX_HTTP_TIMEOUT_SECONDS=15
OLX_USER_AGENT="Mozilla/5.0 (compatible; OLXPriceWatcher/1.0)"

### Subscriptions
SUBSCRIPTION_CONFIRMATION_TTL_HOURS=24

### PHP
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=32M
PHP_POST_MAX_SIZE=32M
PHP_MAX_EXECUTION_TIME=60
PHP_DATE_TIMEZONE=Europe/Kyiv

### Xdebug
# PHP_XDEBUG_MODE examples:
# - off
# - develop
# - debug
# - debug,develop
PHP_XDEBUG_MODE=debug,develop

PHP_XDEBUG_CLIENT_HOST=host.docker.internal
PHP_XDEBUG_CLIENT_PORT=9003
PHP_XDEBUG_IDE_KEY=PHPSTORM

# PHP_XDEBUG_START_WITH_REQUEST values:
# - yes: start debugging for every request
# - no: never start automatically
# - trigger: start only when XDEBUG_TRIGGER is present
# - default: use Xdebug default behavior
PHP_XDEBUG_START_WITH_REQUEST=trigger

# 0 = disabled, 1 = enabled
PHP_XDEBUG_DISCOVER_CLIENT_HOST=0

PHP_XDEBUG_LOG=/tmp/xdebug.log
PHP_XDEBUG_LOG_LEVEL=0
