{
  "name": "yuriy/olx-price-watcher",
  "description": "Small Symfony service for OLX listing price-change subscriptions.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.3",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "ext-mbstring": "*",
    "doctrine/doctrine-bundle": "^2.13",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "doctrine/orm": "^3.3",
    "symfony/console": "^7.2",
    "symfony/dotenv": "^7.2",
    "symfony/flex": "^2.4",
    "symfony/framework-bundle": "^7.2",
    "symfony/http-client": "^7.2",
    "symfony/mailer": "^7.2",
    "symfony/monolog-bundle": "^4.0",
    "symfony/runtime": "^7.2",
    "symfony/translation": "^7.4",
    "symfony/validator": "^7.2",
    "symfony/yaml": "^7.2"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5",
    "squizlabs/php_codesniffer": "^3.11",
    "symfony/browser-kit": "^7.4",
    "symfony/css-selector": "^7.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "platform": {
      "php": "8.3.0"
    },
    "sort-packages": true
  },
  "scripts": {
    "test": "APP_ENV=test vendor/bin/phpunit",
    "coverage": "XDEBUG_MODE=coverage APP_ENV=test vendor/bin/phpunit --coverage-text --coverage-filter src",
    "phpstan": "phpstan analyse",
    "cs-check": "phpcs",
    "cs-fix": "phpcbf",
    "qa": [
      "@cs-check",
      "@phpstan",
      "@test"
    ],
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    }
  }
}
